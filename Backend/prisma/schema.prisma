generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  pemerintah
  gov
  sppg
  sekolah
  umum
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum SppgStatus {
  active
  inactive
  problem
}

enum DistributionStatus {
  draft
  pending
  in_progress
  sent
  delivered
  failed
}

enum MenuPriceValidationStatus {
  PENDING_REVIEW
  VERIFIED
  MISMATCH
}

enum ValidationStatus {
  verified
  conflict
  pending
  issue_reported
}

enum IssueCategory {
  logistik
  keterlambatan
  kekurangan_bahan
  peralatan
  lainnya
}

enum IssueStatus {
  open
  in_progress
  resolved
}

enum ReportCategory {
  kualitas_makanan
  keterlambatan
  kekurangan_porsi
  lainnya
}

enum PublicReportStatus {
  baru
  ditinjau
  ditindak
  ditutup
}

enum AuditAction {
  INSERT
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOCK
  UNLOCK
}

enum AnomalyType {
  OVER_CAPACITY
  PRICE_ANOMALY
  RAW_MATERIAL_PRICE_ANOMALY
  VALIDATION_CONFLICT
  PENDING_TIMEOUT
}

enum FileStatus {
  processing
  ready
  failed
}

enum ExportType {
  pdf
  excel
}

enum ExportStatus {
  pending
  processing
  done
  failed
}

enum NotificationType {
  distribution
  validation
  anomaly
  system
}

model User {
  id                     Int              @id @default(autoincrement())
  name                   String
  email                  String           @unique
  password               String
  role                   UserRole
  sppgId                 Int?             @map("sppg_id")
  schoolId               Int?             @map("school_id")
  isActive               Boolean          @default(true) @map("is_active")
  deletedAt              DateTime?        @map("deleted_at")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")
  sppg                   Sppg?            @relation("SppgUsers", fields: [sppgId], references: [id], onDelete: SetNull)
  school                 School?          @relation("SchoolUsers", fields: [schoolId], references: [id], onDelete: SetNull)
  sessions               UserSession[]
  uploadedProofs         Proof[]          @relation("ProofUploader")
  reportedIssues         Issue[]          @relation("IssueReporter")
  schoolReports          SchoolReport[]   @relation("SchoolReportReporter")
  auditLogs              AuditLog[]       @relation("AuditLogActor")
  resolvedAnomalies      AnomalyLog[]     @relation("AnomalyResolver")
  uploadedFiles          File[]           @relation("FileUploader")
  requestedExports       Export[]         @relation("ExportRequester")
  updatedPriceThresholds PriceThreshold[] @relation("PriceThresholdUpdater")
  updatedSystemConfigs   SystemConfig[]   @relation("SystemConfigUpdater")
  notifications          Notification[]   @relation("UserNotifications")
  validatedMenuPrices    Menu[]           @relation("MenuPriceValidator")
  followedUpPublicReports PublicReport[]   @relation("PublicReportFollower")
  schoolAssignments      SppgSchoolAssignment[]
  permissions            UserPermission[] @relation("UserPermissions")
  grantedPermissions     UserPermission[] @relation("PermissionGrantor")

  @@index([deletedAt], map: "idx_users_deleted_at")
  @@index([sppgId], map: "idx_users_sppg")
  @@index([schoolId], map: "idx_users_school")
  @@map("users")
}

model Permission {
  id              Int              @id @default(autoincrement())
  key             String           @unique
  name            String
  description     String?
  group           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  role         UserRole
  permissionId Int        @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId], map: "role_permissions_role_permission_id_key")
  @@index([role], map: "idx_role_permissions_role")
  @@index([permissionId], map: "idx_role_permissions_permission")
  @@map("role_permissions")
}

model UserPermission {
  id           Int              @id @default(autoincrement())
  userId       Int              @map("user_id")
  permissionId Int              @map("permission_id")
  effect       PermissionEffect
  grantedBy    Int?             @map("granted_by")
  reason       String?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  user         User             @relation("UserPermissions", fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantor      User?            @relation("PermissionGrantor", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@unique([userId, permissionId], map: "user_permissions_user_permission_id_key")
  @@index([userId], map: "idx_user_permissions_user")
  @@index([permissionId], map: "idx_user_permissions_permission")
  @@index([grantedBy], map: "idx_user_permissions_granted_by")
  @@map("user_permissions")
}

model UserSession {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  isRevoked    Boolean  @default(false) @map("is_revoked")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sessions_user")
  @@index([refreshToken], map: "idx_sessions_token")
  @@map("user_sessions")
}

model Sppg {
  id            Int            @id @default(autoincrement())
  name          String
  province      String
  city          String
  address       String?
  lat           Float?
  lng           Float?
  capacity      Int
  workers       Int?
  picName       String?        @map("pic_name")
  picPhone      String?        @map("pic_phone")
  status        SppgStatus     @default(active)
  deletedAt     DateTime?      @map("deleted_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  users         User[]         @relation("SppgUsers")
  schools       School[]
  schoolAssignments SppgSchoolAssignment[]
  distributions Distribution[]
  menus         Menu[]
  issues        Issue[]
  schoolReports SchoolReport[]
  productionBatches ProductionBatch[]

  @@index([province, city], map: "idx_sppg_location")
  @@index([status], map: "idx_sppg_status")
  @@index([deletedAt], map: "idx_sppg_deleted_at")
  @@map("sppg")
}

model School {
  id              Int            @id @default(autoincrement())
  name            String
  province        String
  city            String
  district        String?
  address         String?
  sppgId          Int            @map("sppg_id")
  totalStudents   Int            @default(0) @map("total_students")
  npsn            String?        @unique
  dapodikSchoolId String?        @unique @map("dapodik_school_id")
  educationLevel  String?        @map("education_level")
  schoolStatus    String?        @map("school_status")
  dapodikSyncedAt DateTime?      @map("dapodik_synced_at")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  sppg            Sppg           @relation(fields: [sppgId], references: [id], onDelete: Restrict)
  users           User[]         @relation("SchoolUsers")
  distributions   Distribution[]
  validations     Validation[]
  schoolReports   SchoolReport[]
  dapodikLink     SchoolDapodikLink?
  sppgAssignments SppgSchoolAssignment[]

  @@index([sppgId], map: "idx_schools_sppg")
  @@index([province, city], map: "idx_schools_location")
  @@index([district], map: "idx_schools_district")
  @@index([educationLevel], map: "idx_schools_education_level")
  @@index([schoolStatus], map: "idx_schools_school_status")
  @@index([deletedAt], map: "idx_schools_deleted_at")
  @@map("schools")
}

model SppgSchoolAssignment {
  id           Int       @id @default(autoincrement())
  sppgId       Int       @map("sppg_id")
  schoolId     Int       @map("school_id")
  assignedBy   Int?      @map("assigned_by")
  status       String    @default("active")
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  unassignedAt DateTime? @map("unassigned_at")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  sppg         Sppg      @relation(fields: [sppgId], references: [id], onDelete: Cascade)
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  assigner     User?     @relation(fields: [assignedBy], references: [id], onDelete: SetNull)

  @@index([sppgId, status], map: "idx_sppg_school_assignments_sppg_status")
  @@index([schoolId, status], map: "idx_sppg_school_assignments_school_status")
  @@index([assignedBy], map: "idx_sppg_school_assignments_assigned_by")
  @@map("sppg_school_assignments")
}

model DapodikProvince {
  id            Int               @id @default(autoincrement())
  semesterId    String?           @map("semester_id")
  kodeWilayah   String            @unique @map("kode_wilayah")
  name          String
  idLevelWilayah Int              @map("id_level_wilayah")
  url           String?
  summary       Json?
  rawData       Json?             @map("raw_data")
  importBatchId String?           @map("import_batch_id")
  sourceHash    String?           @map("source_hash")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  cities        DapodikCity[]     @relation("DapodikProvinceCities")
  districts     DapodikDistrict[] @relation("DapodikProvinceDistricts")

  @@index([semesterId], map: "idx_dapodik_provinces_semester")
  @@map("dapodik_provinces")
}

model DapodikCity {
  id                 Int               @id @default(autoincrement())
  semesterId         String?           @map("semester_id")
  kodeWilayah        String            @unique @map("kode_wilayah")
  provinceKodeWilayah String?          @map("province_kode_wilayah")
  name               String
  provinceName       String?           @map("province_name")
  idLevelWilayah     Int               @map("id_level_wilayah")
  url                String?
  summary            Json?
  rawData            Json?             @map("raw_data")
  importBatchId      String?           @map("import_batch_id")
  sourceHash         String?           @map("source_hash")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  province           DapodikProvince?  @relation("DapodikProvinceCities", fields: [provinceKodeWilayah], references: [kodeWilayah], onDelete: SetNull)
  districts          DapodikDistrict[] @relation("DapodikCityDistricts")

  @@index([semesterId], map: "idx_dapodik_cities_semester")
  @@index([provinceKodeWilayah], map: "idx_dapodik_cities_province_kode")
  @@map("dapodik_cities")
}

model DapodikDistrict {
  id                 Int              @id @default(autoincrement())
  semesterId         String?          @map("semester_id")
  kodeWilayah        String           @unique @map("kode_wilayah")
  provinceKodeWilayah String?         @map("province_kode_wilayah")
  cityKodeWilayah    String?          @map("city_kode_wilayah")
  name               String
  provinceName       String?          @map("province_name")
  cityName           String?          @map("city_name")
  idLevelWilayah     Int              @map("id_level_wilayah")
  url                String?
  summary            Json?
  rawData            Json?            @map("raw_data")
  importBatchId      String?          @map("import_batch_id")
  sourceHash         String?          @map("source_hash")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  province           DapodikProvince? @relation("DapodikProvinceDistricts", fields: [provinceKodeWilayah], references: [kodeWilayah], onDelete: SetNull)
  city               DapodikCity?     @relation("DapodikCityDistricts", fields: [cityKodeWilayah], references: [kodeWilayah], onDelete: SetNull)
  schools            DapodikSchool[]

  @@index([semesterId], map: "idx_dapodik_districts_semester")
  @@index([provinceKodeWilayah], map: "idx_dapodik_districts_province_kode")
  @@index([cityKodeWilayah], map: "idx_dapodik_districts_city_kode")
  @@map("dapodik_districts")
}

model DapodikSchool {
  id              Int       @id @default(autoincrement())
  semesterId      String    @map("semester_id")
  dapodikSchoolId String?   @map("dapodik_school_id")
  npsn            String?
  name            String
  bp              String?
  bentukPendidikan String?  @map("bentuk_pendidikan")
  province        String?
  city            String?
  district        String?
  provinceKodeWilayah String? @map("province_kode_wilayah")
  cityKodeWilayah String?  @map("city_kode_wilayah")
  districtKodeWilayah String? @map("district_kode_wilayah")
  educationLevel  String?   @map("education_level")
  schoolStatus    String?   @map("school_status")
  studentCount    Int?      @map("student_count")
  kodeWilayah     String?   @map("kode_wilayah")
  idLevelWilayah  Int?      @map("id_level_wilayah")
  rawData         Json      @map("raw_data")
  fetchedAt       DateTime  @map("fetched_at")
  lastSyncAt      DateTime? @map("last_sync_at")
  importBatchId   String?   @map("import_batch_id")
  sourceHash      String?   @map("source_hash")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  districtRef     DapodikDistrict?   @relation(fields: [districtKodeWilayah], references: [kodeWilayah], onDelete: SetNull)
  schoolLink      SchoolDapodikLink?

  @@unique([semesterId, dapodikSchoolId], map: "dapodik_schools_semester_dapodik_school_key")
  @@unique([semesterId, npsn], map: "dapodik_schools_semester_npsn_key")
  @@index([province, city, district], map: "idx_dapodik_schools_location")
  @@index([kodeWilayah], map: "idx_dapodik_schools_kode_wilayah")
  @@index([provinceKodeWilayah], map: "idx_dapodik_schools_province_kode")
  @@index([cityKodeWilayah], map: "idx_dapodik_schools_city_kode")
  @@index([districtKodeWilayah], map: "idx_dapodik_schools_district_kode")
  @@index([educationLevel], map: "idx_dapodik_schools_education_level")
  @@index([schoolStatus], map: "idx_dapodik_schools_school_status")
  @@index([fetchedAt], map: "idx_dapodik_schools_fetched_at")
  @@index([importBatchId], map: "idx_dapodik_schools_import_batch")
  @@map("dapodik_schools")
}

model DapodikSyncLog {
  id             Int       @id @default(autoincrement())
  endpoint       String
  status         String
  semesterId     String?   @map("semester_id")
  kodeWilayah    String?   @map("kode_wilayah")
  idLevelWilayah Int?      @map("id_level_wilayah")
  educationLevel String?   @map("education_level")
  requestParams  Json      @map("request_params")
  resultMeta     Json?     @map("result_meta")
  errorCode      String?   @map("error_code")
  errorMessage   String?   @map("error_message")
  startedAt      DateTime  @map("started_at")
  finishedAt     DateTime? @map("finished_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([endpoint, kodeWilayah], map: "idx_dapodik_sync_logs_endpoint_kode")
  @@index([status], map: "idx_dapodik_sync_logs_status")
  @@index([createdAt], map: "idx_dapodik_sync_logs_created_at")
  @@map("dapodik_sync_logs")
}

model SchoolDapodikLink {
  id                    Int           @id @default(autoincrement())
  schoolId              Int           @unique @map("school_id")
  dapodikSchoolRecordId Int           @unique @map("dapodik_school_id")
  linkedBy              Int?          @map("linked_by")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  school                School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  dapodikSchool         DapodikSchool @relation(fields: [dapodikSchoolRecordId], references: [id], onDelete: Cascade)

  @@index([linkedBy], map: "idx_school_dapodik_links_linked_by")
  @@map("school_dapodik_links")
}

model Distribution {
  id               Int                @id @default(autoincrement())
  sppgId           Int                @map("sppg_id")
  schoolId         Int                @map("school_id")
  menuId           Int?               @map("menu_id")
  productionBatchId Int?              @map("production_batch_id")
  portions         Int
  pricePerPortion  Decimal            @map("price_per_portion") @db.Decimal(10, 2)
  /// SDD requires this column to be a stored generated field in PostgreSQL.
  totalCost        Decimal            @default(dbgenerated()) @map("total_cost") @db.Decimal(12, 2)
  distributionDate DateTime           @map("distribution_date") @db.Date
  status           DistributionStatus @default(in_progress)
  sentAt           DateTime?          @map("sent_at")
  failureReason    String?            @map("failure_reason")
  isLocked         Boolean            @default(false) @map("is_locked")
  unlockedUntil    DateTime?          @map("unlocked_until")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  sppg             Sppg               @relation(fields: [sppgId], references: [id], onDelete: Restrict)
  school           School             @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  menu             Menu?              @relation(fields: [menuId], references: [id], onDelete: SetNull)
  productionBatch  ProductionBatch?    @relation(fields: [productionBatchId], references: [id], onDelete: SetNull)
  validation       Validation?        @relation("DistributionValidation")
  proofs           Proof[]
  anomalyLogs      AnomalyLog[]
  schoolReports    SchoolReport[]

  @@index([sppgId], map: "idx_distributions_sppg")
  @@index([schoolId], map: "idx_distributions_school")
  @@index([menuId], map: "idx_distributions_menu")
  @@index([productionBatchId], map: "idx_distributions_production_batch")
  @@index([distributionDate], map: "idx_distributions_date")
  @@index([status], map: "idx_distributions_status")
  @@index([unlockedUntil], map: "idx_distributions_unlocked_until")
  @@map("distributions")
}

model Validation {
  id               Int              @id @default(autoincrement())
  distributionId   Int              @unique @map("distribution_id")
  schoolId         Int              @map("school_id")
  receivedPortions Int              @map("received_portions")
  qualityOk        Boolean?         @map("quality_ok")
  status           ValidationStatus @default(pending)
  notes            String?
  validatedAt      DateTime?        @map("validated_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  distribution     Distribution     @relation("DistributionValidation", fields: [distributionId], references: [id], onDelete: Cascade)
  school           School           @relation(fields: [schoolId], references: [id], onDelete: Restrict)

  @@index([schoolId], map: "idx_validations_school")
  @@index([status], map: "idx_validations_status")
  @@map("validations")
}

model Menu {
  id                       Int                       @id @default(autoincrement())
  sppgId                   Int                       @map("sppg_id")
  menuDate                 DateTime                  @map("menu_date") @db.Date
  menuName                 String                    @map("menu_name")
  items                    Json?
  photoFileId              Int?                      @map("photo_file_id")
  manualPricePerPortion    Decimal?                  @map("manual_price_per_portion") @db.Decimal(10, 2)
  priceValidationStatus    MenuPriceValidationStatus @default(PENDING_REVIEW) @map("price_validation_status")
  priceValidationNotes     String?                   @map("price_validation_notes")
  priceValidatedAt         DateTime?                 @map("price_validated_at")
  priceValidatedBy         Int?                      @map("price_validated_by")
  calories                 Int?
  proteinG                 Int?                      @map("protein_g")
  carbsG                   Int?                      @map("carbs_g")
  fatG                     Int?                      @map("fat_g")
  deletedAt                DateTime?                 @map("deleted_at")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  sppg                     Sppg                      @relation(fields: [sppgId], references: [id], onDelete: Cascade)
  photoFile                File?                     @relation("MenuPhoto", fields: [photoFileId], references: [id], onDelete: SetNull)
  priceValidator           User?                     @relation("MenuPriceValidator", fields: [priceValidatedBy], references: [id], onDelete: SetNull)
  productionBatches ProductionBatch[]
  distributions     Distribution[]

  @@unique([sppgId, menuDate], map: "menus_sppg_id_menu_date_key")
  @@index([photoFileId], map: "idx_menus_photo_file")
  @@index([priceValidationStatus], map: "idx_menus_price_validation_status")
  @@index([deletedAt], map: "idx_menus_deleted_at")
  @@map("menus")
}

model ProductionBatch {
  id               Int                   @id @default(autoincrement())
  sppgId           Int                   @map("sppg_id")
  menuId           Int?                  @map("menu_id")
  productionDate   DateTime              @map("production_date") @db.Date
  totalPortions    Int                   @map("total_portions")
  rawMaterialCost  Decimal               @default(0) @map("raw_material_cost") @db.Decimal(14, 2)
  operationalCost  Decimal               @default(0) @map("operational_cost") @db.Decimal(14, 2)
  packagingCost    Decimal               @default(0) @map("packaging_cost") @db.Decimal(14, 2)
  distributionCost Decimal               @default(0) @map("distribution_cost") @db.Decimal(14, 2)
  totalCost        Decimal               @default(0) @map("total_cost") @db.Decimal(14, 2)
  costPerPortion   Decimal               @default(0) @map("cost_per_portion") @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  sppg             Sppg                  @relation(fields: [sppgId], references: [id], onDelete: Cascade)
  menu             Menu?                 @relation(fields: [menuId], references: [id], onDelete: SetNull)
  items            ProductionBatchItem[]
  distributions    Distribution[]
  anomalyLogs      AnomalyLog[]

  @@index([sppgId, productionDate], map: "idx_production_batches_sppg_date")
  @@index([menuId], map: "idx_production_batches_menu")
  @@map("production_batches")
}

model ProductionBatchItem {
  id                     Int              @id @default(autoincrement())
  productionBatchId      Int              @map("production_batch_id")
  commodityName          String           @map("commodity_name")
  variantId              Int?             @map("variant_id")
  quantity               Float
  unit                   String
  unitPrice              Decimal          @map("unit_price") @db.Decimal(12, 2)
  totalPrice             Decimal          @map("total_price") @db.Decimal(14, 2)
  sourcePrice            String?          @map("source_price")
  sourcePriceId          Int?             @map("source_price_id")
  marketReferencePrice   Decimal?         @map("market_reference_price") @db.Decimal(12, 2)
  priceDifferencePercent Decimal?         @map("price_difference_percent") @db.Decimal(8, 2)
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")
  productionBatch        ProductionBatch  @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  sourceFoodPrice        FoodPrice?       @relation(fields: [sourcePriceId], references: [id], onDelete: SetNull)
  anomalyLogs            AnomalyLog[]

  @@index([productionBatchId], map: "idx_production_batch_items_batch")
  @@index([variantId], map: "idx_production_batch_items_variant")
  @@index([sourcePriceId], map: "idx_production_batch_items_source_price")
  @@map("production_batch_items")
}

model Proof {
  id             Int          @id @default(autoincrement())
  distributionId Int          @map("distribution_id")
  fileId         Int          @map("file_id")
  uploadedBy     Int          @map("uploaded_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  distribution   Distribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  file           File         @relation(fields: [fileId], references: [id], onDelete: Restrict)
  uploader       User         @relation("ProofUploader", fields: [uploadedBy], references: [id])

  @@index([distributionId], map: "idx_proofs_distribution")
  @@index([fileId], map: "idx_proofs_file")
  @@map("proofs")
}

model Issue {
  id          Int           @id @default(autoincrement())
  sppgId      Int           @map("sppg_id")
  reportedBy  Int           @map("reported_by")
  category    IssueCategory
  description String
  status      IssueStatus   @default(open)
  deletedAt   DateTime?     @map("deleted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  sppg        Sppg          @relation(fields: [sppgId], references: [id], onDelete: Cascade)
  reporter    User          @relation("IssueReporter", fields: [reportedBy], references: [id])

  @@index([sppgId], map: "idx_issues_sppg")
  @@index([status], map: "idx_issues_status")
  @@index([deletedAt], map: "idx_issues_deleted_at")
  @@map("issues")
}

model SchoolReport {
  id             Int            @id @default(autoincrement())
  schoolId       Int            @map("school_id")
  sppgId         Int?           @map("sppg_id")
  distributionId Int?           @map("distribution_id")
  reportedBy     Int            @map("reported_by")
  category       ReportCategory
  message        String
  createdAt      DateTime       @default(now()) @map("created_at")
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sppg           Sppg?          @relation(fields: [sppgId], references: [id], onDelete: SetNull)
  distribution   Distribution?  @relation(fields: [distributionId], references: [id], onDelete: SetNull)
  reporter       User           @relation("SchoolReportReporter", fields: [reportedBy], references: [id])

  @@index([schoolId], map: "idx_school_reports_school")
  @@index([sppgId], map: "idx_school_reports_sppg")
  @@index([distributionId], map: "idx_school_reports_distribution")
  @@map("school_reports")
}

model PublicReport {
  id             Int                @id @default(autoincrement())
  reporterName   String?            @map("reporter_name")
  category       ReportCategory
  message        String
  province       String?
  city           String?
  status         PublicReportStatus @default(baru)
  followUpNote   String?            @map("follow_up_note")
  followedUpBy   Int?               @map("followed_up_by")
  followedUpAt   DateTime?          @map("followed_up_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  follower       User?              @relation("PublicReportFollower", fields: [followedUpBy], references: [id], onDelete: SetNull)

  @@index([category], map: "idx_public_reports_category")
  @@index([province, city], map: "idx_public_reports_location")
  @@index([status], map: "idx_public_reports_status")
  @@index([followedUpBy], map: "idx_public_reports_followed_up_by")
  @@map("public_reports")
}

model AuditLog {
  id        Int         @id @default(autoincrement())
  userId    Int?        @map("user_id")
  action    AuditAction
  tableName String      @map("table_name")
  recordId  Int         @map("record_id")
  oldData   Json?       @map("old_data")
  newData   Json?       @map("new_data")
  ipAddress String?     @map("ip_address")
  createdAt DateTime    @default(now()) @map("created_at")
  user      User?       @relation("AuditLogActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tableName, recordId], map: "idx_audit_table_record")
  @@index([userId], map: "idx_audit_user")
  @@map("audit_logs")
}

model AnomalyLog {
  id             Int          @id @default(autoincrement())
  distributionId Int?         @map("distribution_id")
  productionBatchId Int?      @map("production_batch_id")
  productionBatchItemId Int?  @map("production_batch_item_id")
  anomalyType    AnomalyType  @map("anomaly_type")
  description    String
  metadata       Json?
  isResolved     Boolean      @default(false) @map("is_resolved")
  resolvedBy     Int?         @map("resolved_by")
  resolvedAt     DateTime?    @map("resolved_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  distribution   Distribution? @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  productionBatch ProductionBatch? @relation(fields: [productionBatchId], references: [id], onDelete: Cascade)
  productionBatchItem ProductionBatchItem? @relation(fields: [productionBatchItemId], references: [id], onDelete: Cascade)
  resolver       User?        @relation("AnomalyResolver", fields: [resolvedBy], references: [id])

  @@index([distributionId], map: "idx_anomaly_logs_distribution")
  @@index([productionBatchId], map: "idx_anomaly_logs_production_batch")
  @@index([productionBatchItemId], map: "idx_anomaly_logs_production_batch_item")
  @@index([anomalyType, isResolved], map: "idx_anomaly_logs_type_resolved")
  @@map("anomaly_logs")
}

model File {
  id           Int        @id @default(autoincrement())
  originalName String     @map("original_name")
  storedName   String     @unique @map("stored_name")
  fileUrl      String     @map("file_url")
  mimeType     String     @map("mime_type")
  sizeBytes    Int        @map("size_bytes")
  uploadedBy   Int        @map("uploaded_by")
  status       FileStatus @default(processing)
  createdAt    DateTime   @default(now()) @map("created_at")
  uploader     User       @relation("FileUploader", fields: [uploadedBy], references: [id])
  proofs       Proof[]
  exports      Export[]
  menuPhotos   Menu[]     @relation("MenuPhoto")

  @@index([uploadedBy], map: "idx_files_uploaded_by")
  @@index([status], map: "idx_files_status")
  @@map("files")
}

model Export {
  id           Int          @id @default(autoincrement())
  userId       Int          @map("user_id")
  type         ExportType
  filterParams Json?        @map("filter_params")
  status       ExportStatus @default(pending)
  fileId       Int?         @map("file_id")
  errorMsg     String?      @map("error_msg")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  user         User         @relation("ExportRequester", fields: [userId], references: [id], onDelete: Cascade)
  file         File?        @relation(fields: [fileId], references: [id])

  @@index([userId], map: "idx_exports_user")
  @@index([status], map: "idx_exports_status")
  @@map("exports")
}

model PriceThreshold {
  id                      Int      @id @default(autoincrement())
  province                String   @unique
  minPrice                Decimal  @map("min_price") @db.Decimal(10, 2)
  maxPrice                Decimal  @map("max_price") @db.Decimal(10, 2)
  avgReferencePrice       Decimal? @map("avg_reference_price") @db.Decimal(10, 2)
  source                  String?
  generatedFromFoodPrices Boolean  @default(false) @map("generated_from_food_prices")
  generatedAt             DateTime? @map("generated_at")
  updatedBy               Int?     @map("updated_by")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  updatedByUser           User?    @relation("PriceThresholdUpdater", fields: [updatedBy], references: [id])

  @@map("price_thresholds")
}

model FoodPrice {
  id             Int      @id @default(autoincrement())
  date           DateTime @db.Date
  source         String
  scope          String
  level          String?
  provinceCode   String?  @map("province_code")
  province       String?
  cityCode       String?  @map("city_code")
  city           String?
  variantId      Int      @map("variant_id")
  variant        String
  unit           String
  quantity       Float    @default(1)
  price          Decimal  @db.Decimal(12, 2)
  sourceEndpoint String?  @map("source_endpoint")
  rawData        Json?    @map("raw_data")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  productionBatchItems ProductionBatchItem[]

  @@unique([date, scope, provinceCode, cityCode, variantId], map: "food_prices_date_scope_province_city_variant_key")
  @@index([date], map: "idx_food_prices_date")
  @@index([province], map: "idx_food_prices_province")
  @@index([city], map: "idx_food_prices_city")
  @@index([variant], map: "idx_food_prices_variant")
  @@index([scope], map: "idx_food_prices_scope")
  @@index([variantId], map: "idx_food_prices_variant_id")
  @@map("food_prices")
}

model SystemConfig {
  id            Int      @id @default(autoincrement())
  key           String   @unique
  value         Json
  description   String?
  updatedBy     Int?     @map("updated_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedByUser User?    @relation("SystemConfigUpdater", fields: [updatedBy], references: [id])

  @@map("system_configs")
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  email     String
  ipAddress String   @map("ip_address")
  success   Boolean
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, createdAt], map: "idx_login_attempts_email")
  @@index([ipAddress, createdAt], map: "idx_login_attempts_ip")
  @@map("login_attempts")
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  type      NotificationType
  title     String
  message   String
  payload   Json?
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead], map: "idx_notifications_user_read")
  @@index([createdAt], map: "idx_notifications_created_at")
  @@map("notifications")
}
